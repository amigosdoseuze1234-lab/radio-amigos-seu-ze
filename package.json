{
  "name": "radio-amigos-seu-ze",
  "version": "2.0.0",
  "description": "Rádio Amigos do Seu Zé - Streaming de Pontos de Umbanda",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "broadcast": "node backend/broadcaster.js",
    "dev": "concurrently \"npm run start\" \"npm run broadcast\"",
    "install-deps": "npm install express ws cors dotenv node-cron",
    "deploy": "node scripts/deploy.js",
    "ssl": "node scripts/ssl-setup.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "radio",
    "streaming",
    "umbanda",
    "icecast",
    "webradio"
  ],
  "author": "Carlos Camargo",
  "license": "MIT"
}